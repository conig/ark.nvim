#!/usr/bin/env sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root=$(CDPATH= cd -- "$script_dir/.." && pwd)
command=${ARK_NVIM_CONSOLE_COMMAND:-Ark console}

export ARK_NVIM_CONSOLE_STANDALONE=1

set --
if [ "${ARK_NVIM_CONSOLE_INIT:-}" ]; then
  set -- "$@" -u "$ARK_NVIM_CONSOLE_INIT"
fi

exec "${ARK_NVIM_CONSOLE_NVIM:-nvim}" \
  "$@" \
  --cmd "let g:ark_console_standalone = v:true" \
  -c "set rtp^=$repo_root" \
  -c "if exists(':Ark') != 2 | runtime plugin/ark.lua | endif" \
  -c "$command" \
  "$@"
