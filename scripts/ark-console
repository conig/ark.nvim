#!/usr/bin/env sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root=$(CDPATH= cd -- "$script_dir/.." && pwd)
command=${ARK_NVIM_CONSOLE_COMMAND:-Ark console}
init=${ARK_NVIM_CONSOLE_INIT:-"$repo_root/scripts/ark-console-init.lua"}

export ARK_NVIM_CONSOLE_STANDALONE=1
export ARK_NVIM_CONSOLE_TERMINAL_UI=1

if [ "$#" -eq 0 ]; then
  set -- \
    -n \
    --cmd "let g:ark_console_standalone = v:true" \
    --cmd "let g:ark_console_terminal_ui = v:true" \
    -u "$init" \
    -c "$command"
fi

exec "${ARK_NVIM_CONSOLE_NVIM:-nvim}" "$@"
